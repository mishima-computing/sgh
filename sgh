#!/usr/bin/env python3
"""
sgh: secure gh wrapper.

MVP goals:
- Wrap gh with the same arguments by default.
- Scan high-risk GitHub publish surfaces before dispatch.
- Block deterministic PII/contact/denylist findings.
- Emit an LLM review packet for ambiguous human/agent judgement.
"""

from __future__ import annotations

import argparse
import fnmatch
import hashlib
import json
import os
import re
import subprocess
import sys
from dataclasses import dataclass, asdict
from pathlib import Path
from typing import Iterable


VERSION = "0.1.0"
DEFAULT_GH = "/usr/bin/gh"
DEFAULT_GIT = "/usr/bin/git"

EMAIL_RE = re.compile(r"\b[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}\b")
PHONE_RE = re.compile(
    r"(?<!\w)(?:\+?\d{1,3}[-.\s]?)?(?:\(?\d{2,4}\)?[-.\s]?){2,4}\d{3,4}(?!\w)"
)
CONTACT_HANDLE_RE = re.compile(
    r"(?i)\b(?:contact|email|mail|slack|discord|twitter|x|github|連絡|メール|slack)[:：\s]+@[A-Za-z0-9_.\-]{3,}\b"
)

RAW_FILENAME_PATTERNS = [
    "*.people.*",
    "*never-record*",
    "*hearing*",
    "*minutes*",
    "*transcript*",
    "*議事録*",
    "*.jsonl",
]

HIGH_RISK_WORDS = [
    "client",
    "customer",
    "customer call",
    "meeting notes",
    "minutes",
    "transcript",
    "hearing",
    "nda",
    "internal",
    "confidential",
    "personally identifiable",
    "pii",
    "顧客",
    "取引先",
    "議事録",
    "逐語録",
    "社内",
    "機密",
    "個人情報",
    "部長",
    "社長",
    "役員",
    "法務",
    "営業",
