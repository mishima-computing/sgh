@dataclass
class ScanUnit:
    location: str
    text: str


@dataclass
class Finding:
    location: str
    span: str
    category: str
    confidence: float
    reason: str


def eprint(*args: object) -> None:
    print(*args, file=sys.stderr)


def find_repo_root(start: Path) -> Path:
    cur = start.resolve()
    for parent in [cur, *cur.parents]:
        if (parent / ".git").exists() or (parent / ".leakguard").exists():
            return parent
    return cur


def read_lines(path: Path) -> list[str]:
    if not path.exists():
        return []
    try:
        return [
            line.strip()
            for line in path.read_text(encoding="utf-8").splitlines()
            if line.strip() and not line.lstrip().startswith("#")
        ]
    except UnicodeDecodeError:
        return []


def load_policy(cwd: Path) -> tuple[list[str], list[str]]:
    root = find_repo_root(cwd)
    leakguard = root / ".leakguard"
    deny = read_lines(leakguard / "denylist.txt")
    allow = read_lines(leakguard / "allowlist.txt")

    config = leakguard / "config.yaml"
    if config.exists():
        # Minimal YAML-ish allowlist reader. Full YAML is intentionally avoided
        # to keep the wrapper dependency-free.
        in_allowlist = False
        for raw in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if re.match(r"^allowlist\s*:", line):
                in_allowlist = True
                continue
            if in_allowlist:
                if line.startswith("- "):
                    allow.append(line[2:].strip().strip("\"'"))
                    continue
                if re.match(r"^[A-Za-z0-9_.-]+\s*:", line):
                    in_allowlist = False
    return unique_nonempty(deny), unique_nonempty(allow)


def unique_nonempty(items: Iterable[str]) -> list[str]:
    seen: set[str] = set()
    out: list[str] = []
    for item in items:
        value = item.strip()
        if value and value not in seen:
            seen.add(value)
            out.append(value)
    return out


def is_allowed(span: str, allowlist: list[str]) -> bool:
    low = span.casefold()
    if low.endswith("@users.noreply.github.com"):
        return True
    return any(term.casefold() == low or term.casefold() in low for term in allowlist)


def find_denylist(text: str, location: str, denylist: list[str], allowlist: list[str]) -> list[Finding]:
    findings: list[Finding] = []
    folded = text.casefold()
    for term in denylist:
        if is_allowed(term, allowlist):
            continue
        needle = term.casefold()
        if not needle:
            continue
        if len(term) <= 2:
            pattern = re.compile(rf"(?<![\w]){re.escape(term)}(?![\w])", re.IGNORECASE)
            matches = [m.group(0) for m in pattern.finditer(text)]
        else:
            matches = [term] if needle in folded else []
        for span in matches:
            findings.append(
                Finding(
                    location=location,
                    span=span,
                    category="denylist",
                    confidence=1.0,
                    reason="Term appears in .leakguard/denylist.txt.",
                )
            )
    return findings


def scan_text(unit: ScanUnit, denylist: list[str], allowlist: list[str]) -> list[Finding]:
    text = unit.text or ""
    findings = find_denylist(text, unit.location, denylist, allowlist)

    for match in EMAIL_RE.finditer(text):
        span = match.group(0)
        if not is_allowed(span, allowlist):
            findings.append(
                Finding(unit.location, span, "email", 0.99, "Personal/contact email address.")
            )

    for match in PHONE_RE.finditer(text):
        span = match.group(0)
        digits = re.sub(r"\D", "", span)
        if len(digits) >= 9 and not is_allowed(span, allowlist):
            findings.append(
                Finding(unit.location, span, "phone", 0.9, "Possible phone number.")
            )

    for match in CONTACT_HANDLE_RE.finditer(text):
        span = match.group(0)
        if not is_allowed(span, allowlist):
            findings.append(
                Finding(unit.location, span, "contact-handle", 0.8, "Social/account handle used as contact info.")
            )

    return findings


def scan_personal_namespace(unit: ScanUnit, login: str, allowlist: list[str]) -> list[Finding]:
    if not login or is_allowed(login, allowlist):
        return []
    if unit.location == "repo-name":
        return []

    repo_owner = current_repo_owner()
    if not repo_owner or repo_owner.casefold() == login.casefold():
        return []

    patterns = [
        re.compile(rf"(?<![\w.-]){re.escape(login)}/[A-Za-z0-9_.-]+(?![\w.-])"),
        re.compile(rf"https://github\.com/{re.escape(login)}/[A-Za-z0-9_.-]+", re.IGNORECASE),
    ]
    findings: list[Finding] = []
    for pattern in patterns:
        for match in pattern.finditer(unit.text):
            findings.append(
                Finding(
                    unit.location,
                    match.group(0),
                    "cross-namespace-personal-reference",
                    0.9,
                    f"Authenticated personal GitHub namespace appears while working in {repo_owner!r}.",
                )
            )
    return findings


def risky_filename_findings(args: list[str], allowlist: list[str]) -> list[Finding]:
    findings: list[Finding] = []
    for arg in args:
        name = Path(arg).name
        for pattern in RAW_FILENAME_PATTERNS:
            if fnmatch.fnmatch(name.casefold(), pattern.casefold()) and not is_allowed(name, allowlist):
                findings.append(
                    Finding(
                        "arg:filename",
                        arg,
                        "raw-data-filename",
                        0.75,
                        f"Filename matches high-risk pattern {pattern!r}.",
                    )
                )
                break
    return findings


def ignored_tracked_file_findings(units: list[ScanUnit], allowlist: list[str]) -> list[Finding]:
    findings: list[Finding] = []
    for unit in units:
        if unit.location != "git-push:tracked-ignored-files":
            continue
        for path in unit.text.splitlines():
            if not path.strip() or is_allowed(path, allowlist):
                continue
            findings.append(
                Finding(
                    unit.location,
                    path,
                    "tracked-ignored-file",
                    0.95,
                    "File is tracked by Git even though it matches current ignore rules; remove it from the index with git rm --cached.",
                )
            )
    return findings


def read_arg_file(path_text: str) -> str:
    path = Path(path_text)
    if not path.exists() or not path.is_file():
        return ""
    if path.stat().st_size > 512_000:
        return f"[sgh skipped large file: {path}]"
    return path.read_text(encoding="utf-8", errors="ignore")


def option_value(args: list[str], names: set[str]) -> list[tuple[int, str, str]]:
    values: list[tuple[int, str, str]] = []
    i = 0
    while i < len(args):
        arg = args[i]
        if "=" in arg:
            key, value = arg.split("=", 1)
            if key in names:
                values.append((i, key, value))
        elif arg in names and i + 1 < len(args):
            values.append((i, arg, args[i + 1]))
            i += 1
        i += 1
    return values


def positional_after_command(args: list[str], start: int) -> list[str]:
    out: list[str] = []
    skip_next = False
    options_with_value = {
        "-R", "--repo", "-t", "--title", "-b", "--body", "-F", "--body-file",
        "--notes", "--notes-file", "--name", "--description", "--homepage",
        "--discussion-category", "--target", "--base", "--head", "--label",
        "--assignee", "--milestone", "--template", "--web",
    }
    for arg in args[start:]:
        if skip_next:
            skip_next = False
            continue
        if arg in options_with_value:
            skip_next = True
            continue
        if arg.startswith("-"):
            continue
        out.append(arg)
    return out


def collect_units(args: list[str]) -> list[ScanUnit]:
    units: list[ScanUnit] = []
    if not args:
        return units

    command = args[0]
    sub = args[1] if len(args) > 1 else ""

    def add_opts(names: set[str], label: str, file_backed: bool = False) -> None:
        for _, name, value in option_value(args, names):
            text = read_arg_file(value) if file_backed else value
            units.append(ScanUnit(f"{label}:{name}", text))

    if command == "git" and sub == "push":
        units.extend(collect_git_push_units())

    elif command == "pr":
        if sub in {"create", "edit"}:
            add_opts({"-t", "--title"}, "pr-title")
            add_opts({"-b", "--body"}, "pr-body")
            add_opts({"-F", "--body-file"}, "pr-body-file", file_backed=True)
        elif sub == "comment":
            add_opts({"-b", "--body"}, "pr-comment")
            add_opts({"-F", "--body-file"}, "pr-comment-file", file_backed=True)
        elif sub == "review":
            add_opts({"-b", "--body"}, "review-comment")
            add_opts({"-F", "--body-file"}, "review-comment-file", file_backed=True)

    elif command == "issue":
        if sub in {"create", "edit"}:
            add_opts({"-t", "--title"}, "issue-title")
            add_opts({"-b", "--body"}, "issue-body")
            add_opts({"-F", "--body-file"}, "issue-body-file", file_backed=True)
        elif sub == "comment":
            add_opts({"-b", "--body"}, "issue-comment")
            add_opts({"-F", "--body-file"}, "issue-comment-file", file_backed=True)

    elif command == "release" and sub in {"create", "edit"}:
        add_opts({"--title"}, "release-title")
        add_opts({"--notes"}, "release")
        add_opts({"--notes-file"}, "release-file", file_backed=True)
        for pos in positional_after_command(args, 2):
            units.append(ScanUnit("release-arg", pos))

    elif command == "repo" and sub in {"create", "edit"}:
        add_opts({"--description"}, "repo-metadata")
        add_opts({"--homepage"}, "repo-metadata")
        for pos in positional_after_command(args, 2)[:1]:
            units.append(ScanUnit("repo-name", pos))

    elif command == "gist" and sub in {"create", "edit"}:
        add_opts({"-d", "--desc"}, "gist-description")
        for pos in positional_after_command(args, 2):
            units.append(ScanUnit("gist-arg", pos))
            text = read_arg_file(pos)
            if text:
                units.append(ScanUnit(f"gist-file:{pos}", text))

    elif command == "api":
        # gh api can create comments/releases/checks via raw fields. Scan common
        # body-ish parameters without trying to fully understand the endpoint.
        for _, name, value in option_value(args, {"-f", "-F", "--field", "--raw-field"}):
            if re.match(r"(?i)^(body|title|name|description|summary|text|notes)=", value):
                key, text = value.split("=", 1)
                units.append(ScanUnit(f"api-field:{key}", text))
            else:
                units.append(ScanUnit(f"api-field:{name}", value))

    return [unit for unit in units if unit.text]


def run_capture(command: list[str]) -> str:
    try:
        result = subprocess.run(
            command,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except FileNotFoundError:
        return ""
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def current_gh_login() -> str:
    gh = os.environ.get("SGH_REAL_GH", DEFAULT_GH)
    try:
        result = subprocess.run(
            [gh, "api", "user", "--jq", ".login"],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=3,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def current_repo_owner() -> str:
    git = os.environ.get("SGH_REAL_GIT", DEFAULT_GIT)
    remote = run_capture([git, "remote", "get-url", "origin"])
    if not remote:
        return ""

    patterns = [
        r"^https://github\.com/([^/]+)/[^/]+(?:\.git)?$",
        r"^git@github\.com:([^/]+)/[^/]+(?:\.git)?$",
    ]
    for pattern in patterns:
        match = re.match(pattern, remote)
        if match:
            return match.group(1)
    return ""


def collect_git_push_units() -> list[ScanUnit]:
    units: list[ScanUnit] = []
    git = os.environ.get("SGH_REAL_GIT", DEFAULT_GIT)

    branch = run_capture([git, "symbolic-ref", "--short", "HEAD"])
    if branch:
        units.append(ScanUnit("branch", branch))

    upstream = run_capture([git, "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"])
    if upstream:
        rev_range = f"{upstream}..HEAD"
    else:
        default_branch = run_capture([git, "rev-parse", "--verify", "origin/main"])
        rev_range = "origin/main..HEAD" if default_branch else "HEAD"

    commit_format = "%H%n%an%n%ae%n%cn%n%ce%n%B%n---SGH-COMMIT---"
    commits = run_capture([git, "log", rev_range, f"--format={commit_format}"])
    if commits:
        units.append(ScanUnit("git-push:commit-metadata-and-messages", commits))

    commit_ids = run_capture([git, "log", "--reverse", "--format=%H", rev_range])
    for commit_id in commit_ids.splitlines():
        patch = run_capture([git, "show", "--format=", "--unified=0", "--no-ext-diff", commit_id])
        added = extract_added_diff_text(patch)
        if not added:
            continue
        if len(added) > 100_000:
            added = added[:100_000] + "\n...[truncated by sgh]..."
        units.append(ScanUnit(f"git-push:commit:{commit_id[:12]}:added-lines", added))

    names = run_capture([git, "diff", "--name-only", rev_range])
    if names:
        units.append(ScanUnit("git-push:changed-files", names))

    tracked_ignored = run_capture([git, "ls-files", "-ci", "--exclude-standard"])
    if tracked_ignored:
        units.append(ScanUnit("git-push:tracked-ignored-files", tracked_ignored))

    diff = run_capture([git, "diff", "--unified=0", "--no-ext-diff", rev_range])
    if diff:
        diff = extract_added_diff_text(diff)
        if len(diff) > 200_000:
            diff = diff[:200_000] + "\n...[truncated by sgh]..."
        if diff:
            units.append(ScanUnit("git-push:diff", diff))

    return units


def extract_added_diff_text(diff: str) -> str:
    lines: list[str] = []
    for line in diff.splitlines():
        if not line.startswith("+") or line.startswith("+++"):
            continue
        lines.append(line[1:])
    return "\n".join(lines)


def needs_llm_review(units: list[ScanUnit]) -> bool:
    combined = "\n".join(unit.text for unit in units).casefold()
    return any(word.casefold() in combined for word in HIGH_RISK_WORDS)


def llm_packet(args: list[str], units: list[ScanUnit], findings: list[Finding]) -> dict:
    redacted_units = []
    for unit in units:
        text = redact_text(unit.text)
        if len(text) > 4000:
            text = text[:4000] + "\n...[truncated by sgh]..."
        redacted_units.append({"location": unit.location, "text": text})

    payload = {
        "tool": "sgh",
        "version": VERSION,
        "decision_requested": len(findings) == 0,
        "recommended_action": "block" if findings else "ask_llm_then_continue_or_block",
        "command_shape": redact_command(args),
        "content_hash": hashlib.sha256(
            "\n---\n".join(unit.location + "\n" + unit.text for unit in units).encode("utf-8")
        ).hexdigest(),
        "findings": [asdict(f) for f in findings],
        "scan_units": redacted_units,
        "llm_instruction": (
            "Classify whether this outgoing GitHub operation leaks real person names, "
            "client/company names, personal contact info, meeting/transcript/case data, "
            "internal attribution such as 'requested by a named manager', internal politics, "
            "confidential context, customer-specific exceptions, or re-identifying summaries. "
            "Use categories such as pii, client-name, contact-info, meeting-notes, "
            "internal-attribution, internal-politics, customer-specific-exception, and reidentification-risk. "
            "Return JSON: {decision: 'allow'|'block'|'redact', findings: [...], suggested_redactions: [...]}."
        ),
    }
    return payload


def redact_text(text: str) -> str:
    text = EMAIL_RE.sub("<email>", text)
    text = PHONE_RE.sub("<phone>", text)
    text = CONTACT_HANDLE_RE.sub("<contact-handle>", text)
    return text


def redact_command(args: list[str]) -> list[str]:
    if args[:2] == ["git", "push"]:
        return args

    redacted = ["gh"]
    body_like = {
        "-b", "--body", "-t", "--title", "--notes", "--description", "--homepage",
        "-d", "--desc", "--raw-field", "--field", "-f", "-F",
    }
    skip_value = False
    for arg in args:
        if skip_value:
            redacted.append(redact_text(arg))
            skip_value = False
            continue
        if "=" in arg:
            key, value = arg.split("=", 1)
            if key in body_like or re.match(r"(?i)^(body|title|name|description|summary|text|notes)$", key.lstrip("-")):
                redacted.append(key + "=" + redact_text(value))
            else:
                redacted.append(arg)
            continue
        redacted.append(arg)
        if arg in body_like:
            skip_value = True
    return redacted


def print_findings(findings: list[Finding]) -> None:
    eprint("sgh: blocked GitHub operation")
    for f in findings:
        eprint(f"{f.location} — {f.span} — {f.category} — {f.reason}")
    eprint("")
    eprint('To allowlist a public-safe term: add it to .leakguard/allowlist.txt')
    eprint("For LLM review: rerun with --llm-packet")


def run_target(args: list[str]) -> int:
    if args[:2] == ["git", "push"]:
        git = os.environ.get("SGH_REAL_GIT", DEFAULT_GIT)
        try:
            os.execv(git, [git, *args[1:]])
        except FileNotFoundError:
            eprint(f"sgh: real git not found: {git}")
            return 127

    gh = os.environ.get("SGH_REAL_GH", DEFAULT_GH)
    try:
        os.execv(gh, [gh, *args])
    except FileNotFoundError:
        eprint(f"sgh: real gh not found: {gh}")
        return 127
    return 1


def parse_sgh_args(argv: list[str]) -> tuple[argparse.Namespace, list[str]]:
    parser = argparse.ArgumentParser(
        prog="sgh",
        description="Secure wrapper for gh and git push that scans outgoing GitHub text before publishing.",
        add_help=True,
    )
    parser.add_argument("--version", action="store_true", help="Print sgh version.")
    parser.add_argument("--dry-run", action="store_true", help="Scan and show the target command without executing it.")
    parser.add_argument("--audit-json", action="store_true", help="Print scan result JSON.")
    parser.add_argument("--llm-packet", action="store_true", help="Print an LLM decision packet and do not execute gh.")
    parser.add_argument("--no-llm-hint", action="store_true", help="Do not warn on high-risk text that needs semantic review.")
    parser.add_argument("gh_args", nargs=argparse.REMAINDER)
    ns = parser.parse_args(argv)
    args = ns.gh_args
    if args and args[0] == "--":
        args = args[1:]
    return ns, args


def main(argv: list[str]) -> int:
    ns, gh_args = parse_sgh_args(argv)
    if ns.version:
        print(f"sgh {VERSION}")
        return 0
    if not gh_args:
        eprint("sgh: no arguments supplied")
        eprint("usage: sgh [--dry-run] [--llm-packet] <gh args...>")
        eprint("       sgh git push [git push args...]")
        return 2

    cwd = Path.cwd()
    denylist, allowlist = load_policy(cwd)
    units = collect_units(gh_args)
    findings = risky_filename_findings(gh_args, allowlist)
    findings.extend(ignored_tracked_file_findings(units, allowlist))
    login = current_gh_login()
    for unit in units:
        findings.extend(scan_text(unit, denylist, allowlist))
        findings.extend(scan_personal_namespace(unit, login, allowlist))

    if ns.audit_json:
        print(json.dumps({
            "command": command_shape(gh_args),
            "scan_units": [asdict(u) for u in units],
            "findings": [asdict(f) for f in findings],
            "would_block": bool(findings),
            "needs_llm_review": needs_llm_review(units),
        }, ensure_ascii=False, indent=2))

    if ns.llm_packet:
        print(json.dumps(llm_packet(gh_args, units, findings), ensure_ascii=False, indent=2))
        return 0 if not findings else 3

    if findings:
        print_findings(findings)
        return 3

    if units and not ns.no_llm_hint and needs_llm_review(units):
        eprint("sgh: semantic-risk hint")
        eprint("This operation contains words that often indicate client/case/meeting data or internal attribution.")
        eprint("For agent judgement, run: sgh --llm-packet " + " ".join(shell_quote(a) for a in gh_args))
        eprint("Continuing because no deterministic block was found.")

    if ns.dry_run:
        print("sgh: clean")
        print("would run:", " ".join(shell_quote(a) for a in command_shape(gh_args)))
        return 0

    return run_target(gh_args)


def command_shape(args: list[str]) -> list[str]:
    if args[:2] == ["git", "push"]:
        return args
    return ["gh", *args]


def shell_quote(value: str) -> str:
    if re.fullmatch(r"[A-Za-z0-9_./:=@%+\-]+", value):
        return value
    return "'" + value.replace("'", "'\"'\"'") + "'"


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
